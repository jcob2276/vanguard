{
  "name": "vanguard-os",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint . --max-warnings=600",
    "preview": "vite preview",
    "typecheck": "node scripts/ops/check-edge-functions.mjs",
    "typecheck:ui": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:edge": "deno test --no-check supabase/functions/_shared",
    "db:update-types": "npx supabase gen types typescript --project-id pdvqkgfsqziqlhptatgf > src/lib/database.types.ts",
    "db:check-drift": "node scripts/ops/check-migration-drift.mjs",
    "audit:registry": "node scripts/analysis/audit-registry.mjs",
    "smoke:ui": "node scripts/ops/smoke-ui.mjs",
    "oss:audit": "node scripts/ops/oss-audit.mjs",
    "smoke": "node scripts/ops/smoke-vanguard.mjs --with-service-role",
    "smoke:safe": "node scripts/ops/smoke-vanguard.mjs --with-service-role --invoke-safe",
    "e2e:loop": "node scripts/ops/e2e-daily-loop.mjs",
    "audit:knip": "knip"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.101.2",
    "date-fns": "^4.1.0",
    "exifr": "^7.1.3",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-body-highlighter": "^2.0.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "source-map-js": "^1.2.1",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "knip": "^6.24.0",
    "postcss": "^8.5.12",
    "supabase": "^2.98.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.9"
  }
