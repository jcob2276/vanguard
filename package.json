{
  "name": "vanguard-os",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint . --max-warnings=532",
    "preview": "vite preview",
    "typecheck": "node scripts/ops/check-edge-functions.mjs",
    "typecheck:ui": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:edge": "deno test --no-check supabase/functions/_shared",
    "db:update-types": "npx supabase gen types typescript --project-id pdvqkgfsqziqlhptatgf > src/lib/database.types.ts && cp src/lib/database.types.ts supabase/functions/_shared/database.types.ts",
    "db:check-drift": "node scripts/ops/check-migration-drift.mjs",
    "registry:generate": "node scripts/ops/generate-functions-registry.mjs",
    "check:edge": "node scripts/ops/check-edge-functions.mjs",
    "audit:registry": "node scripts/analysis/audit-registry.mjs",
    "smoke:ui": "node scripts/ops/smoke-ui.mjs",
    "oss:audit": "node scripts/ops/oss-audit.mjs",
    "smoke": "node scripts/ops/smoke-vanguard.mjs --with-service-role",
    "smoke:safe": "node scripts/ops/smoke-vanguard.mjs --with-service-role --invoke-safe",
    "e2e:loop": "node scripts/ops/e2e-daily-loop.mjs",
    "audit:knip": "knip",
    "ratchet:frontend": "node scripts/ops/check-frontend-ratchets.mjs",
    "ratchet:backend": "node scripts/ops/check-backend-contract.mjs",
    "contracts:check": "node scripts/ops/check-data-contracts.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "supabase/functions/**/*.ts": "node scripts/ops/check-line-limit.mjs"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.101.2",
    "date-fns": "^4.1.0",
    "exifr": "^7.1.3",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-body-highlighter": "^2.0.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "source-map-js": "^1.2.1",
    "suncalc": "^2.0.0",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.12",
    "supabase": "^2.98.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.9"
  }
}
