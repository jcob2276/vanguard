{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "supabase/functions/*/index.ts",
    "scripts/**/*.{mjs,ts,cjs}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "supabase/functions/**/*.ts"
  ],
  "ignore": [
    "supabase/functions/**/*.test.ts",
    "src/sw.ts",
    "src/lib/database.types.ts",
    "src/components/projects/HealthScore.tsx",
    "src/components/projects/ProjectCard.tsx",
    "src/components/projects/ProjectCardCollapsed.tsx",
    "src/components/projects/ProjectCardExpanded.tsx",
    "src/components/projects/ProjectCardWrapper.tsx",
    "src/components/projects/ProjectEvidenceStrip.tsx",
    "src/lib/projects/projectEvidence.ts",
    "supabase/functions/_shared/database.types.ts",
    "supabase/functions/_shared/repos/**"
  ],
  "ignoreIssues": {
    "src/lib/native/platform.ts": ["exports"],
    "src/lib/todo/todo.ts": ["exports"],
    "src/lib/projects/projects.ts": ["exports"],
    "src/components/projects/projectUtils.ts": ["exports", "types"],
    "src/components/lifestyle/links/useLinksInboxData.ts": ["exports"],
    "src/components/projects/useProjectsData.ts": ["exports"],
    "src/components/core/nutrition/hooks/useFoodEntryLists.ts": ["exports"],
    "src/components/lifestyle/direction/hooks/useDirection.ts": ["exports"],
    "src/components/growth/hooks/useGrowthData.ts": ["exports", "types"],
    "src/lib/systemApi.ts": ["exports", "types"],
    "src/components/core/useNutritionData.ts": ["exports", "types"],
    "supabase/functions/_shared/foodParseCore.ts": ["exports"],
    "supabase/functions/_shared/foodParse/matching.ts": ["exports"]
  },
  "ignoreDependencies": [
    "npm"
  ]
}
